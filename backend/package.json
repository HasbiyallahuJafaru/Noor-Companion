{
  "name": "noor-companion-backend",
  "version": "1.0.0",
  "description": "Noor Companion API — Node.js + Express + Prisma + Supabase Auth",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "db:migrate": "npx prisma migrate dev",
    "db:deploy": "npx prisma migrate deploy",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "clearMocks": true,
    "transformIgnorePatterns": [
      "node_modules/(?!(@paralleldrive/cuid2)/)"
    ]
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.50.0",
    "@supabase/supabase-js": "^2.104.1",
    "agora-token": "^2.0.5",
    "bullmq": "^5.76.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "firebase-admin": "^13.8.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "resend": "^6.12.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "pg": "^8.20.0",
    "prisma": "^5.22.0"
  },
  "engines": {
    "node": ">=20"
  }
}
