NODE_ENV=development
PORT=3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Prisma — use pooled URL for app, direct for migrations
DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
DIRECT_DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Subscriptions
SUBSCRIPTION_TOKEN_SECRET=change-me-to-a-random-64-char-string

# Upstash Redis
UPSTASH_REDIS_URL=rediss://:your-token@your-project.upstash.io:6380

# Paystack
PAYSTACK_SECRET_KEY=sk_live_xxxxx

# Agora
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-app-certificate

# Firebase Admin
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Resend
RESEND_API_KEY=re_xxxxx
FROM_EMAIL=noreply@noorcompanion.com

# Sentry
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Website
WEBSITE_URL=https://noorcompanion.netlify.app
